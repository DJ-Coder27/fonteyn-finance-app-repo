<canvas id="monthlySalesChart" width="700" height="350"></canvas>

<script src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.8.5/d3.min.js"></script>

<script>
    const canvas = document.getElementById("monthlySalesChart");
    const context = canvas.getContext("2d");

    const margin = { top: 30, right: 20, bottom: 40, left: 60 };
    const width = canvas.width - margin.left - margin.right;
    const height = canvas.height - margin.top - margin.bottom;

    context.translate(margin.left, margin.top);

    d3.json("@ViewBag.ApiMontlySales")
        .then(function (response) {
            let data = response;

            if (typeof response === "string") {
                data = JSON.parse(response);
            }

            if (!Array.isArray(data) || data.length === 0) {
                context.fillStyle = "black";
                context.font = "16px Arial";
                context.fillText("No monthly sales data available.", 20, 30);
                return;
            }

            data.forEach(function (d) {
                d.month = d.month;
                d.amount = +d.amount;
            });

            const x = d3.scaleBand()
                .rangeRound([0, width])
                .padding(0.1)
                .domain(data.map(function (d) { return d.month; }));

            const y = d3.scaleLinear()
                .rangeRound([height, 0])
                .domain([0, d3.max(data, function (d) { return d.amount; })]);

            context.clearRect(-margin.left, -margin.top, canvas.width, canvas.height);

            context.fillStyle = "black";
            context.font = "bold 16px Arial";
            context.fillText("Monthly Sales", 10, -5);

            context.beginPath();
            x.domain().forEach(function (d) {
                context.moveTo(x(d) + x.bandwidth() / 2, height);
                context.lineTo(x(d) + x.bandwidth() / 2, height + 6);
            });
            context.strokeStyle = "black";
            context.stroke();

            context.textAlign = "center";
            context.textBaseline = "top";
            context.font = "12px Arial";
            x.domain().forEach(function (d) {
                context.fillText(d, x(d) + x.bandwidth() / 2, height + 10);
            });

            const yTicks = y.ticks(8);

            context.beginPath();
            yTicks.forEach(function (d) {
                context.moveTo(0, y(d));
                context.lineTo(-6, y(d));
            });
            context.stroke();

            context.textAlign = "right";
            context.textBaseline = "middle";
            yTicks.forEach(function (d) {
                context.fillText(d, -10, y(d));
            });

            context.beginPath();
            context.moveTo(0, 0);
            context.lineTo(0, height);
            context.lineTo(width, height);
            context.stroke();

            context.fillStyle = "steelblue";
            data.forEach(function (d) {
                context.fillRect(x(d.month), y(d.amount), x.bandwidth(), height - y(d.amount));
            });
        })
        .catch(function (error) {
            context.fillStyle = "black";
            context.font = "16px Arial";
            context.fillText("Could not load monthly sales data from the API.", 20, 30);
            console.error(error);
        });
</script>