<!DOCTYPE html>
<html lang="en">
<head>
    <base href="~/" />
    <component type="typeof(Microsoft.AspNetCore.Components.Web.HeadOutlet)"
               render-mode="ServerPrerendered" />

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">
    <meta name="description" content="Finance App - Accounting System">

    <title>Finance App</title>

    <link rel="icon" type="image/x-icon" href="~/images/favicon.ico">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/simple-line-icons/2.5.5/css/simple-line-icons.min.css" rel="stylesheet">
    <link href="~/css/dark.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/pace-js@latest/pace-theme-default.min.css" rel="stylesheet">

    <style>
        body {
            margin: 0;
            background-color: #2f2f2f;
            color: #f5f5f5;
            font-family: Arial, Helvetica, sans-serif;
        }

        .app-header {
            height: 56px;
            background-color: #1f2933;
            border-bottom: 1px solid #3a4652;
            display: flex;
            align-items: center;
            padding: 0 20px;
        }

        .navbar-brand {
            color: #ffffff;
            font-size: 22px;
            font-weight: 700;
            text-decoration: none;
        }

        .navbar-brand:hover {
            color: #ffffff;
        }

        .app-body {
            display: flex;
            min-height: calc(100vh - 96px);
        }

        .sidebar {
            width: 260px;
            background-color: #202a35;
            padding: 15px 0;
            border-right: 1px solid #3a4652;
        }

        .sidebar-title {
            color: #9fd3ff;
            font-size: 12px;
            text-transform: uppercase;
            padding: 10px 20px;
            letter-spacing: 0.5px;
        }

        .sidebar a {
            display: block;
            color: #d9edf7;
            text-decoration: none;
            padding: 9px 20px;
            font-size: 15px;
        }

        .sidebar a:hover {
            background-color: #2f80c1;
            color: #ffffff;
        }

        .sidebar .sub-link {
            padding-left: 38px;
            font-size: 14px;
            color: #bfe5ff;
        }

        .main-content {
            flex: 1;
            padding: 25px;
            overflow-x: auto;
        }

        .page-title {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 20px;
            color: #ffffff;
        }

        .app-footer {
            min-height: 40px;
            background-color: #1f2933;
            color: #d9edf7;
            border-top: 1px solid #3a4652;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 20px;
            font-size: 13px;
        }

        .app-footer a {
            color: #9fd3ff;
            text-decoration: none;
        }

        .content-card {
            background-color: #383838;
            border: 1px solid #4a4a4a;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
        }

        table {
            color: #f5f5f5;
        }

        canvas {
            background-color: #ffffff;
            border-radius: 6px;
            padding: 10px;
        }
    </style>
</head>

<body>
    <header class="app-header">
        <a class="navbar-brand" href="/">
            Finance App
        </a>
    </header>

    <div class="app-body">
        <nav class="sidebar">
            <div class="sidebar-title">Main</div>

            <a asp-area="" asp-controller="Dashboard" asp-action="MonthlySales">
                <i class="fa fa-dashboard"></i> Dashboard
            </a>

            <div class="sidebar-title">Accounts Receivable</div>
            <a class="sub-link" asp-area="" asp-controller="Quotations" asp-action="Quotations">Sales Quotations</a>
            <a class="sub-link" asp-area="" asp-controller="Sales" asp-action="SalesOrders">Sales Orders</a>
            <a class="sub-link" asp-area="" asp-controller="Sales" asp-action="SalesReceipts">Sales Receipts</a>
            <a class="sub-link" asp-area="" asp-controller="Sales" asp-action="SalesInvoices">Sales Invoices</a>
            <a class="sub-link" asp-area="" asp-controller="Sales" asp-action="DonationInvoices">Donation Invoices</a>
            <a class="sub-link" asp-area="" asp-controller="Sales" asp-action="Customers">Customers</a>

            <div class="sidebar-title">Accounts Payable</div>
            <a class="sub-link" asp-area="" asp-controller="Purchasing" asp-action="PurchaseOrders">Purchase Orders</a>
            <a class="sub-link" asp-area="" asp-controller="Purchasing" asp-action="PurchaseInvoices">Purchase Invoices</a>
            <a class="sub-link" asp-area="" asp-controller="Purchasing" asp-action="Vendors">Vendors</a>

            <div class="sidebar-title">Inventory</div>
            <a class="sub-link" asp-area="" asp-controller="Inventory" asp-action="Index">Items</a>
            <a class="sub-link" asp-area="" asp-controller="Inventory" asp-action="ICJ">Inventory Control Journal</a>

            <div class="sidebar-title">Financials</div>
            <a class="sub-link" asp-area="" asp-controller="Financials" asp-action="JournalEntries">Journal Entries</a>
            <a class="sub-link" asp-area="" asp-controller="Financials" asp-action="GeneralLedger">General Ledgers</a>
            <a class="sub-link" asp-area="" asp-controller="Tax" asp-action="Taxes">Taxes</a>
            <a class="sub-link" asp-area="" asp-controller="Financials" asp-action="Accounts">Chart of Accounts</a>
            <a class="sub-link" asp-area="" asp-controller="Financials" asp-action="Banks">Banks</a>

            <div class="sidebar-title">Reports</div>
            <a class="sub-link" asp-area="" asp-controller="Financials" asp-action="BalanceSheet">Balance Sheet</a>
            <a class="sub-link" asp-area="" asp-controller="Financials" asp-action="IncomeStatement">Income Statement</a>
            <a class="sub-link" asp-area="" asp-controller="Financials" asp-action="TrialBalance">Trial Balance</a>

            <div class="sidebar-title">Organization</div>
            <a class="sub-link" asp-area="" asp-controller="Administration" asp-action="Company">Company</a>
            <a class="sub-link" asp-area="" asp-controller="Administration" asp-action="Settings">Settings</a>

            <div class="sidebar-title">System Administration</div>
            <a class="sub-link" href="~/administration/users">Users</a>
            <a class="sub-link" href="~/administration/roles">Roles</a>
            <a class="sub-link" href="~/administration/groups">Groups</a>
            <a class="sub-link" href="~/administration/auditlogs">Audit Logs</a>
        </nav>

        <main class="main-content">
            <div class="page-title">
                @Html.Raw(ViewBag.PageContentHeader)
            </div>

            @RenderBody()
        </main>
    </div>

    <footer class="app-footer">
        <div>
            <strong>Finance App</strong>
            <span>&copy; @DateTime.Now.Year All rights reserved.</span>
        </div>
        <div>
            <span>Containerized for</span>
            <a href="/">Fonteyn Holiday Parks</a>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.12.9/dist/umd/popper.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.2.0/js/bootstrap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/pace-js@latest/pace.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.perfect-scrollbar/1.5.5/perfect-scrollbar.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@coreui/coreui@4.3.2/dist/js/coreui.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/ag-grid/31.0.1/ag-grid-community.min.js"></script>
    <script src="~/_framework/blazor.server.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>