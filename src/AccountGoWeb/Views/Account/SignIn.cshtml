@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Finance App Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background-color: #f5f7fa;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-page {
            width: 100%;
            max-width: 760px;
            min-height: 360px;
            border: 3px solid #111827;
            background-color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-box {
            width: 320px;
            border: 3px solid #111827;
            padding: 30px;
            text-align: center;
            background-color: #ffffff;
        }

        .login-title {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 12px;
            color: #111827;
        }

        .login-text {
            font-size: 15px;
            margin-bottom: 24px;
            color: #374151;
        }

        .login-button {
            width: 100%;
            padding: 12px 16px;
            border: none;
            background-color: #2563eb;
            color: #ffffff;
            font-size: 15px;
            font-weight: 700;
            cursor: pointer;
            border-radius: 4px;
        }

        .login-button:hover {
            background-color: #1d4ed8;
        }
    </style>
</head>
<body>
    <main class="login-page">
        <section class="login-box">
            <div class="login-title">Finance App</div>
            <div class="login-text">Sign in with your Microsoft account to continue.</div>

            <form asp-controller="Account" asp-action="MicrosoftLogin" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="/" />
                <button type="submit" class="login-button">
                    Login with Microsoft account
                </button>
            </form>
        </section>
    </main>
</body>
</html>